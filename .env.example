# ─── Discord Account ────────────────────────────────────────────────────────────
# Your Discord USER token (NOT a bot token)
# How to get it: DevTools → Network → any Discord request → look for Authorization header
TOKEN=your_discord_user_token_here

# Sofi bot's user ID (default is the official Sofi bot ID, change if using a test bot)
SOFI_BOT_ID=853629533855809596

# ─── Dry Run Mode ───────────────────────────────────────────────────────────────
# Set to true to log what the bot WOULD do without actually clicking any buttons
# Great for testing that parsing and decision logic works correctly
DRY_RUN=false

# ─── Log Level ──────────────────────────────────────────────────────────────────
# Options: error, warn, info, debug
LOG_LEVEL=info

# ─── Channel IDs (optional override) ────────────────────────────────────────────
# Comma-separated channel IDs for this account to drop in.
# Preferred: set per-instance in ecosystem.config.js env block instead of here.
# Falls back to the CHANNELS array in config/index.js if not set.
# CHANNEL_IDS=925595419256451077,1331257457128771654
